[Unit]
Description=WxStream Scanner Service
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
User=root
WorkingDirectory=/root/wxstream-rs
EnvironmentFile=/root/wxstream-rs/.env
ExecStart=/root/wxstream-rs/target/release/wxstream --service scanner
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=wxstream-scanner

[Install]
WantedBy=multi-user.target
